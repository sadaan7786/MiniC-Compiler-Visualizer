Terminals unused in grammar

    RETURN
    COMMA


Grammar

    0 $accept: program $end

    1 program: stmts

    2 stmts: stmts stmt
    3      | stmt

    4 stmt: decl
    5     | assign_stmt
    6     | if_stmt
    7     | while_stmt
    8     | print_stmt

    9 decl: INT ID_TOK SEMI
   10     | FLOAT ID_TOK SEMI

   11 assign_stmt: ID_TOK ASSIGN expr SEMI

   12 if_stmt: IF LPAREN rel_expr RPAREN block
   13        | IF LPAREN rel_expr RPAREN block ELSE block

   14 while_stmt: WHILE LPAREN rel_expr RPAREN block

   15 print_stmt: PRINT LPAREN expr RPAREN SEMI

   16 block: LBRACE stmts RBRACE
   17      | LBRACE RBRACE

   18 rel_expr: expr EQ expr
   19         | expr NEQ expr
   20         | expr LT expr
   21         | expr GT expr
   22         | expr LEQ expr
   23         | expr GEQ expr

   24 expr: expr PLUS expr
   25     | expr MINUS expr
   26     | expr STAR expr
   27     | expr SLASH expr
   28     | expr MOD expr
   29     | MINUS expr
   30     | LPAREN expr RPAREN
   31     | ID_TOK
   32     | INT_NUM
   33     | FLOAT_NUM


